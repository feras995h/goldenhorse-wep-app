{
  "name": "Golden Horse Shipping System",
  "description": "نظام إدارة شركة الحصان الذهبي للشحن والنقل",
  "type": "application",
  "framework": "nodejs",
  "buildCommand": "chmod +x deploy-coolify.sh",
  "startCommand": "./deploy-coolify.sh",
  "port": 5001,
  "healthCheck": {
    "path": "/api/health",
    "interval": 30,
    "timeout": 10,
    "retries": 3
  },
  "environment": {
    "NODE_ENV": "production",
    "PORT": "5001"
  },
  "requiredEnvironmentVariables": [
    "DB_HOST",
    "DB_NAME", 
    "DB_USERNAME",
    "DB_PASSWORD",
    "JWT_SECRET",
    "JWT_REFRESH_SECRET"
  ],
  "optionalEnvironmentVariables": [
    "REDIS_URL",
    "CORS_ORIGIN",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASSWORD",
    "SMTP_FROM"
  ],
  "volumes": [
    {
      "source": "./uploads",
      "target": "/app/server/uploads"
    },
    {
      "source": "./logs", 
      "target": "/app/server/logs"
    },
    {
      "source": "./backups",
      "target": "/app/server/backups"
    }
  ],
  "dependencies": {
    "postgresql": {
      "required": true,
      "version": "15"
    },
    "redis": {
      "required": false,
      "version": "7"
    }
  },
  "deployment": {
    "preDeployScript": "chmod +x deploy.sh",
    "postDeployScript": "./deploy.sh",
    "migrations": "cd server && npm run db:migrate && npm run seed-basic-data"
  }
}
