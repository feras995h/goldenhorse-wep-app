# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Configuration - CHANGE THESE IN PRODUCTION
JWT_SECRET=your-super-secure-jwt-secret-key-here-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-here-minimum-32-characters
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Database Configuration (Development)
DB_USERNAME=postgres
DB_PASSWORD=your_database_password
DB_NAME=golden_horse_dev
DB_HOST=localhost
DB_PORT=5432

# Database Configuration (Production)
# DB_USERNAME=your_production_db_user
# DB_PASSWORD=your_production_db_password
# DB_NAME=your_production_db_name
# DB_HOST=your_production_db_host
# DB_PORT=5432

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Security Configuration
TRUST_PROXY=0
CORS_ORIGIN=http://localhost:3000

# Redis Configuration (Optional - for JWT blacklist and caching)
REDIS_URL=redis://localhost:6379

# Logging Configuration
LOG_LEVEL=info

# Hostinger API Configuration
# HOSTINGER_API_KEY=your_hostinger_api_key_here

# VPS Configuration
# VPS_IP=your_vps_ip_here
# SSH_USERNAME=your_ssh_username
# VPS_SSH_PASSWORD=your_ssh_password

# Email Configuration (for notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_email_password

# Backup Configuration
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30
