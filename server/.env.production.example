# Golden Horse Shipping System - Production Environment Configuration
# Copy this file to .env and update the values for your production environment

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database type: postgres, mysql, or sqlite
DB_TYPE=postgres

# PostgreSQL Configuration (Recommended for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=golden_horse_production
DB_USER=golden_horse_user
DB_PASSWORD=your_secure_database_password

# MySQL Configuration (Alternative)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=golden_horse_production
# DB_USER=golden_horse_user
# DB_PASSWORD=your_secure_database_password

# SQLite Configuration (Not recommended for production)
# DB_PATH=./database/production.sqlite

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Generate a strong secret key (at least 32 characters)
JWT_SECRET=your_very_secure_jwt_secret_key_minimum_32_characters_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=5001
HOST=0.0.0.0

# CORS Configuration - Update with your domain
CORS_ORIGIN=https://yourdomain.com
# For multiple domains: CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session security
SESSION_SECRET=your_secure_session_secret_key

# Password policy
MIN_PASSWORD_LENGTH=8
REQUIRE_STRONG_PASSWORD=true

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
# SMTP Configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# Email settings
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Golden Horse Shipping

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Maximum file size in MB
MAX_FILE_SIZE=10

# Allowed file types
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Upload directory
UPLOAD_DIR=./uploads

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Enable automatic backups
BACKUP_ENABLED=true

# Backup directory
BACKUP_PATH=/var/backups/golden-horse

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log directory
LOG_DIR=./logs

# Log rotation
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Redis configuration (if using Redis for caching)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_DB=0

# Cache TTL in seconds
CACHE_TTL=3600

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# Health check endpoint
HEALTH_CHECK_ENABLED=true

# Metrics collection
METRICS_ENABLED=true

# Performance monitoring
APM_ENABLED=false
APM_SERVICE_NAME=golden-horse-api

# =============================================================================
# COMPANY CONFIGURATION
# =============================================================================
# Default company information (can be changed from admin panel)
COMPANY_NAME=شركة الحصان الذهبي للشحن
COMPANY_NAME_EN=Golden Horse Shipping
COMPANY_TIMEZONE=Africa/Tripoli
DEFAULT_CURRENCY=LYD

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
ENABLE_REGISTRATION=false
ENABLE_PASSWORD_RESET=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_TWO_FACTOR_AUTH=false

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# Payment gateway configuration (if needed)
# PAYMENT_GATEWAY_API_KEY=your_payment_gateway_api_key
# PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret

# SMS service configuration (if needed)
# SMS_API_KEY=your_sms_api_key
# SMS_SENDER_ID=GoldenHorse

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
# SSL certificate paths (if handling SSL in Node.js)
# SSL_CERT_PATH=/path/to/certificate.crt
# SSL_KEY_PATH=/path/to/private.key

# Force HTTPS
FORCE_HTTPS=true

# =============================================================================
# DATABASE POOL CONFIGURATION
# =============================================================================
# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# =============================================================================
# DEVELOPMENT/DEBUG (Set to false in production)
# =============================================================================
DEBUG=false
ENABLE_CORS_DEBUG=false
ENABLE_SQL_LOGGING=false
