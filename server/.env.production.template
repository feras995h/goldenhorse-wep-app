# Production Environment Configuration Template
# Copy this file to .env.production and update with your actual values

# Server Configuration
PORT=5001
NODE_ENV=production

# JWT Configuration - CHANGE THESE IN PRODUCTION!
JWT_SECRET=CHANGE-THIS-TO-A-VERY-SECURE-SECRET-KEY-IN-PRODUCTION
JWT_REFRESH_SECRET=CHANGE-THIS-TO-A-VERY-SECURE-REFRESH-SECRET-KEY-IN-PRODUCTION
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Database Configuration (Coolify/Hostinger PostgreSQL)
DB_USERNAME=golden_horse_user
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD_HERE
DB_NAME=golden_horse_production
DB_HOST=YOUR_VPS_IP_OR_DOMAIN_HERE
DB_PORT=5432

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Security Configuration
TRUST_PROXY=1
CORS_ORIGIN=https://your-domain.com

# Redis Configuration (Recommended for production)
REDIS_URL=redis://localhost:6379

# Logging Configuration
LOG_LEVEL=warn

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Monitoring Configuration
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true
