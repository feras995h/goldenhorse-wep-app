# Coolify Configuration
# This file tells Coolify how to build and deploy the application

# Build configuration
BUILD_COMMAND="npm ci && cd client && npm ci && npm run build && cd ../server && npm ci --only=production"

# Start command
START_COMMAND="cd server && npm start"

# Port
PORT=5001

# Health check
HEALTH_CHECK_PATH="/api/health"

# Environment
NODE_ENV=production
